---
const base = import.meta.env.BASE_URL;
---

<nav id="main-nav" style="position:fixed;top:0;left:0;right:0;z-index:100;transition:background 0.3s,box-shadow 0.3s;padding:0.75rem 1.5rem;display:flex;align-items:center;justify-content:space-between;">
  <!-- Logo -->
  <a href={`${base}/#hero`} style="display:flex;align-items:center;gap:0.75rem;text-decoration:none;">
    <span style="font-family:'Cinzel',serif;font-size:1.6rem;font-weight:900;letter-spacing:0.1em;color:var(--color-gold);text-shadow:0 0 20px rgba(212,175,55,0.5);">ZLAVIA</span>
    <span style="font-size:0.65rem;font-family:'Lora',serif;color:var(--color-text-muted);letter-spacing:0.15em;text-transform:uppercase;display:none;" class="nav-sub">Gra Planszowa</span>
  </a>

  <!-- Desktop links -->
  <div class="nav-links" style="display:flex;align-items:center;gap:2rem;">
    <a href={`${base}/#about`} class="nav-link" data-pl="O Grze" data-en="About">O Grze</a>
    <a href={`${base}/#classes`} class="nav-link" data-pl="Klasy" data-en="Classes">Klasy</a>
    <a href={`${base}/#bestiary`} class="nav-link" data-pl="Bestiariusz" data-en="Bestiary">Bestiariusz</a>
    <a href={`${base}/#hexmap`} class="nav-link" data-pl="Mapa" data-en="Map">Mapa</a>
    <a href={`${base}feedback`} class="nav-link" data-pl="Feedback" data-en="Feedback">Feedback</a>

    <!-- Lang toggle -->
    <div style="display:flex;gap:0.25rem;margin-left:0.5rem;">
      <button class="lang-btn active" data-lang-target="pl">PL</button>
      <button class="lang-btn" data-lang-target="en">EN</button>
    </div>

    <a href={`${base}/#join`} class="btn-gold" style="padding:0.5rem 1.25rem;font-size:0.85rem;" data-pl="Dołącz" data-en="Join">Dołącz</a>
  </div>

  <!-- Mobile hamburger -->
  <button id="nav-hamburger" aria-label="Menu" style="display:none;background:none;border:none;cursor:pointer;flex-direction:column;gap:5px;padding:4px;">
    <span style="display:block;width:24px;height:2px;background:var(--color-gold);border-radius:2px;"></span>
    <span style="display:block;width:24px;height:2px;background:var(--color-gold);border-radius:2px;"></span>
    <span style="display:block;width:24px;height:2px;background:var(--color-gold);border-radius:2px;"></span>
  </button>
</nav>

<!-- Mobile menu -->
<div id="mobile-menu" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:var(--color-bg-deep);z-index:120;flex-direction:column;align-items:center;justify-content:center;gap:2rem;">
  <button id="mobile-close" style="position:absolute;top:1.5rem;right:1.5rem;background:none;border:none;color:var(--color-gold);font-size:1.5rem;cursor:pointer;">✕</button>
  <a href={`${base}/#about`} class="mobile-link" data-pl="O Grze" data-en="About">O Grze</a>
  <a href={`${base}/#classes`} class="mobile-link" data-pl="Klasy" data-en="Classes">Klasy</a>
  <a href={`${base}/#bestiary`} class="mobile-link" data-pl="Bestiariusz" data-en="Bestiary">Bestiariusz</a>
  <a href={`${base}/#hexmap`} class="mobile-link" data-pl="Mapa" data-en="Map">Mapa</a>
  <a href={`${base}feedback`} class="mobile-link" data-pl="Feedback" data-en="Feedback">Feedback</a>
  <a href={`${base}/#join`} class="mobile-link" data-pl="Dołącz" data-en="Join">Dołącz</a>
  <div style="display:flex;gap:0.5rem;margin-top:1rem;">
    <button class="lang-btn active" data-lang-target="pl">PL</button>
    <button class="lang-btn" data-lang-target="en">EN</button>
  </div>
</div>

<style>
  .nav-link {
    font-family: 'Cinzel', serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-link:hover { color: var(--color-gold); }

  .mobile-link {
    font-family: 'Cinzel', serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.1em;
    transition: color 0.2s;
  }
  .mobile-link:hover { color: var(--color-gold); }

  @media (max-width: 768px) {
    .nav-links { display: none !important; }
    #nav-hamburger { display: flex !important; }
    .nav-sub { display: block !important; }
  }
</style>

<script is:inline>
  var mobileMenu = document.getElementById('mobile-menu');
  var hamburger = document.getElementById('nav-hamburger');
  var mobileClose = document.getElementById('mobile-close');

  function setMobileMenu(open) {
    mobileMenu.style.display = open ? 'flex' : 'none';
    hamburger.setAttribute('aria-expanded', open ? 'true' : 'false');
    document.body.style.overflow = open ? 'hidden' : '';
  }

  // Nav scroll effect
  window.addEventListener('scroll', function() {
    var nav = document.getElementById('main-nav');
    if (window.scrollY > 50) {
      nav.style.background = 'rgba(17,10,5,0.97)';
      nav.style.boxShadow = '0 2px 20px rgba(0,0,0,0.5)';
      nav.style.borderBottom = '1px solid rgba(107,74,32,0.4)';
    } else {
      nav.style.background = 'transparent';
      nav.style.boxShadow = 'none';
      nav.style.borderBottom = 'none';
    }
  });

  // Mobile menu
  hamburger.addEventListener('click', function() {
    setMobileMenu(mobileMenu.style.display !== 'flex');
  });
  mobileClose.addEventListener('click', function() {
    setMobileMenu(false);
  });
  document.querySelectorAll('.mobile-link').forEach(function(link) {
    link.addEventListener('click', function() {
      setMobileMenu(false);
    });
  });
  document.addEventListener('keydown', function(event) {
    if (event.key === 'Escape') {
      setMobileMenu(false);
    }
  });
</script>
