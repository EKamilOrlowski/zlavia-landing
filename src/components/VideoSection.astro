---
// Video IDs to embed — replace with actual YouTube video IDs
const videos = [
  { id: 'dQw4w9WgXcQ', titlePl: 'Devlog #1 — Mechanika walki', titleEn: 'Devlog #1 — Combat mechanics' },
  { id: 'dQw4w9WgXcQ', titlePl: 'Devlog #2 — Klasy postaci', titleEn: 'Devlog #2 — Character classes' },
  { id: 'dQw4w9WgXcQ', titlePl: 'Devlog #3 — Słowiański klimat', titleEn: 'Devlog #3 — Slavic atmosphere' },
];
---

<section id="videos" style="padding:6rem 1.5rem;background:var(--color-bg-primary);">
  <div style="max-width:1100px;margin:0 auto;">

    <h2 class="section-title" data-pl="Devlog" data-en="Devlog">Devlog</h2>
    <p class="section-sub" data-pl="Śledź postępy prac nad grą" data-en="Follow the development progress">Śledź postępy prac nad grą</p>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.5rem;">
      {videos.map(v => (
        <div class="card" style="padding:0;overflow:hidden;border-radius:8px;">
          <div style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;background:#000;">
            <iframe
              src={`https://www.youtube.com/embed/${v.id}`}
              title={v.titlePl}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
              style="position:absolute;top:0;left:0;width:100%;height:100%;border:none;"
            ></iframe>
          </div>
          <div style="padding:1rem 1.25rem;">
            <p style="font-family:'Cinzel',serif;font-size:0.9rem;color:var(--color-gold);margin:0;" data-pl={v.titlePl} data-en={v.titleEn}>{v.titlePl}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
